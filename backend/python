ffmpeg_cmd = [
    "ffmpeg", "-rtsp_transport", "tcp",
    "-i", RTSP_URL,
    "-vf", f"scale={WIDTH}:{HEIGHT}",
    "-f", "rawvideo", "-pix_fmt", "bgr24", "-"
]

pipe = subprocess.Popen(ffmpeg_cmd, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL)

# ── Boucle détection ──────────────────────────────────────
prev_gray = None
buffer = []

print("Détection active...")

while True:
    raw = pipe.stdout.read(WIDTH * HEIGHT * 3)
    if len(raw) != WIDTH * HEIGHT * 3:
        continue

    frame = np.frombuffer(raw, np.uint8).reshape((HEIGHT, WIDTH, 3))
    buffer.append(frame.copy())
    if len(buffer) > FPS * BUFFER_SECONDS:
        buffer.pop(0)

    gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
    gray = cv2.GaussianBlur(gray, (21, 21), 0)

    if prev_gray is None:
        prev_gray = gray
        continue

    delta = cv2.absdiff(prev_gray, gray)
    thresh = cv2.threshold(delta, 25, 255, cv2.THRESH_BINARY)[1]
    motion_score = np.sum(thresh) / 255

    contours, _ = cv2.findContours(thresh, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
    has_human = any(cv2.contourArea(c) > MIN_CONTOUR_AREA for c in contours)

    if motion_score > MOTION_THRESHOLD and has_human:
        now = datetime.now()
        ts = now.strftime("%Y%m%d_%H%M%S")
        date_heure = now.strftime("%d/%m/%Y à %Hh%M")

        print(f"INTRUSION → {date_heure} (score {int(motion_score)})")

        base = f"intrus_{ts}"

        photo = SAVE_FOLDER / f"{base}.jpg"
        cv2.imwrite(str(photo), frame)

        video = SAVE_FOLDER / f"clip_{ts}.mp4"
        out = cv2.VideoWriter(str(video), cv2.VideoWriter_fourcc(*"mp4v"), FPS, (WIDTH, HEIGHT))
        for f in buffer:
            out.write(f)
        out.write(frame)
        out.release()

        pdf = SAVE_FOLDER / f"{base}.pdf"
        generate_pdf(pdf, date_heure)

        # ── EMAIL ────────────────────────────────────────
