    table.setStyle([
        ('GRID', (0,0), (-1,-1), 0.5, colors.black),
        ('BACKGROUND', (0,0), (-1,0), colors.lightgrey),
    ])

    story.append(table)
    story.append(Spacer(1, 24))
    story.append(Paragraph("Photo et vidéo en pièce jointe email", styles['Normal']))
