def generate_pdf(pdf_path: Path, date_heure: str):
    styles = getSampleStyleSheet()
    doc = SimpleDocTemplate(str(pdf_path), pagesize=letter)
    story = []

    story.append(Paragraph("VIDA Secure AI", styles['Title']))
    story.append(Spacer(1, 12))
